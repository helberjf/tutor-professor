# =============================================================================
# VARIÁVEIS DE AMBIENTE — apps/web
# =============================================================================
# Para uso LOCAL: copie para apps/web/.env.local e ajuste os valores.
# Para a VERCEL:  cole diretamente em Settings → Environment Variables.
#
# Atenção: na Vercel NÃO defina NEXT_PUBLIC_API_BASE_URL (a URL do backend é
# resolvida dinamicamente via KV / GitHub). Defina somente as variáveis abaixo.
# =============================================================================

# -----------------------------------------------------------------------------
# [OBRIGATÓRIO] Token secreto que autentica a ativação do backend local.
# Crie qualquer senha segura (ex: openssl rand -hex 32).
# Deve ser IDÊNTICO ao ENGLISH_TUTOR_VERCEL_SYNC_TOKEN em local.secrets.
# -----------------------------------------------------------------------------
VERCEL_BACKEND_SYNC_TOKEN=

# -----------------------------------------------------------------------------
# [STORAGE — escolha pelo menos 1]
#
# Opção A — Vercel KV (recomendado):
#   No painel da Vercel: Storage → Create → KV Database
#   As duas variáveis abaixo são preenchidas automaticamente ao vincular o KV.
# -----------------------------------------------------------------------------
KV_REST_API_URL=
KV_REST_API_TOKEN=

# -----------------------------------------------------------------------------
# Opção B — GitHub Token (alternativa sem banco de dados):
#   Crie em: https://github.com/settings/tokens → classic → permissão "repo"
#   O frontend usará o branch "runtime-state" do repositório para salvar a URL.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# [APENAS LOCAL — não definir na Vercel]
# URL do backend em desenvolvimento. Em produção a URL vem do KV/GitHub.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
